# ─── Application ────────────────────────────────────────────────
# Public canonical URL of the deployed site. Feeds sitemap.xml,
# robots.txt, OG image meta, canonical links. Include scheme, no
# trailing slash.
NEXT_PUBLIC_SITE_URL=https://build.store

# ─── Postgres (active) ──────────────────────────────────────────
# Connection string to the Dokploy-hosted Postgres 18 instance.
# Use the INTERNAL Docker DNS hostname (external access should be
# off on the DB service for security). Drizzle client + seed script
# both read this.
DATABASE_URL=postgresql://appuser:REPLACE_ME@future-modern-database-9v4pfx:5432/app

# ─── HubSpot CRM (active) ───────────────────────────────────────
# Private App access token from HubSpot Settings → Integrations →
# Private Apps → Auth. Scopes required: crm.objects.contacts.write,
# crm.objects.deals.write, crm.schemas.contacts.read,
# crm.schemas.deals.read.
HUBSPOT_ACCESS_TOKEN=

# App client secret from developers.hubspot.com → your app → Auth.
# Used to verify inbound webhook signatures on
# /api/hooks/hubspot/stage. Route fails closed without it.
HUBSPOT_APP_CLIENT_SECRET=

# ─── Auth.js (production activation) ────────────────────────────
# Wire these when Tolgay/Billy activates Auth.js per production-
# swap-checklist §2. Sandbox uses auth-stub.ts and ignores them.

# Random 32+ char secret for signing session tokens. Generate via
# `openssl rand -base64 32`.
AUTH_SECRET=

# Auth.js canonical URL. Same as NEXT_PUBLIC_SITE_URL typically.
AUTH_URL=https://build.store

# Email magic-link provider (primary auth path)
EMAIL_SERVER_HOST=
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=
EMAIL_FROM="Future Modern <hello@build.store>"

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple OAuth
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
